<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:label="FoodOrder"
        android:icon="@mipmap/ic_food_logo1_round"
        android:roundIcon="@mipmap/ic_food_logo1_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FoodOrder">

        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.FoodOrder.Splash">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity android:name=".MenuListActivity" android:exported="false" />
        <activity android:name=".FoodDetailActivity" android:exported="false" />

    </application>

</manifest>